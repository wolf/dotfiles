{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(ls:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git switch:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh repo view:*)",
      "Bash(gh release:*)",
      "Bash(pytest:*)",
      "Bash(pixi run pytest:*)",
      "Bash(bash:*)",
      "Write(~/Vaults/**)",
      "Edit(~/Vaults/**)",
      "WebSearch",
      "WebFetch",
      "mcp__omnifocus__get_focus",
      "mcp__omnifocus__get_folders",
      "mcp__omnifocus__get_perspectives",
      "mcp__omnifocus__get_projects",
      "mcp__omnifocus__get_tags",
      "mcp__omnifocus__get_tasks",
      "mcp__mcp-atlassian__jira_get_agile_boards",
      "mcp__mcp-atlassian__jira_get_all_projects",
      "mcp__mcp-atlassian__jira_get_board_issues",
      "mcp__mcp-atlassian__jira_get_field_options",
      "mcp__mcp-atlassian__jira_get_issue",
      "mcp__mcp-atlassian__jira_get_issue_dates",
      "mcp__mcp-atlassian__jira_get_issue_development_info",
      "mcp__mcp-atlassian__jira_get_issue_images",
      "mcp__mcp-atlassian__jira_get_issue_proforma_forms",
      "mcp__mcp-atlassian__jira_get_issue_sla",
      "mcp__mcp-atlassian__jira_get_issue_watchers",
      "mcp__mcp-atlassian__jira_get_issues_development_info",
      "mcp__mcp-atlassian__jira_get_link_types",
      "mcp__mcp-atlassian__jira_get_proforma_form_details",
      "mcp__mcp-atlassian__jira_get_project_components",
      "mcp__mcp-atlassian__jira_get_project_issues",
      "mcp__mcp-atlassian__jira_get_project_versions",
      "mcp__mcp-atlassian__jira_get_queue_issues",
      "mcp__mcp-atlassian__jira_get_service_desk_for_project",
      "mcp__mcp-atlassian__jira_get_service_desk_queues",
      "mcp__mcp-atlassian__jira_get_sprint_issues",
      "mcp__mcp-atlassian__jira_get_sprints_from_board",
      "mcp__mcp-atlassian__jira_get_transitions",
      "mcp__mcp-atlassian__jira_get_user_profile",
      "mcp__mcp-atlassian__jira_get_worklog",
      "mcp__mcp-atlassian__jira_search",
      "mcp__mcp-atlassian__jira_search_fields",
      "Write(~/.claude/**)",
      "Edit(~/.claude/**)"
    ],
    "additionalDirectories": [
      "~/develop/",
      "~/Vaults/",
      "~/.claude/"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/bin/statusline.bash"
  },
  "autoUpdatesChannel": "latest",
  "voiceEnabled": true,
  "theme": "light",
  "model": "opusplan",
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TTY\" ] && printf '\\033]0;%s (Claude)\\007' \"${PWD##*/}\" > \"$TTY\" || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TTY\" ] && printf '\\033]0;%s (Claude)\\007' \"${PWD##*/}\" > \"$TTY\" || true"
          }
        ]
      }
    ]
  }
}
